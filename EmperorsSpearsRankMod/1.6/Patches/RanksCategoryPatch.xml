                    <!-- Main line -->
                    <li>
                        <rankDef>FERP_EmperorsSpearsRankNeophyte</rankDef>
                        <displayPosition>(0, 0)</displayPosition>
                    </li>
                    <li>
                        <rankDef>FERP_EmperorsSpearsRankBattleBrother</rankDef>
