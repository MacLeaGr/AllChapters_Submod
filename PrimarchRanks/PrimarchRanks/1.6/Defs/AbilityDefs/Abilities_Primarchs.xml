<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- Primarch: Command -->
    <AbilityDef>
        <defName>FERP_PrimarchsOrder</defName>
        <label>Primarch's Order</label>
        <description>The Primarch issues a powerful command that rallies nearby allies and increases their combat effectiveness. The command increases their strength, precision, and morale, allowing them to fight with greater coordination and ferocity. The effect remains attached to the caster for 48 hours.</description>
        <iconPath>UI/Abilities/BEWH_AbilityCaptainsOrder</iconPath>
        <jobDef>CastAbilityOnThing</jobDef>
        <targetRequired>False</targetRequired>
        <canUseAoeToGetTargets>False</canUseAoeToGetTargets>
        <stunTargetWhileCasting>True</stunTargetWhileCasting>
        <showPsycastEffects>False</showPsycastEffects>
        <sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
        <displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
        <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
        <statBases>
            <Ability_Duration>2000</Ability_Duration>
            <Ability_EffectRadius>11.9</Ability_EffectRadius>
        </statBases>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <warmupTime>0.3</warmupTime>
            <range>11.9</range>
            <drawAimPie>False</drawAimPie>
            <requireLineOfSight>False</requireLineOfSight>
            <soundCast>BEWH_SFX_CaptainsOrder</soundCast>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
                <canTargetPawns>false</canTargetPawns>
                <canTargetBuildings>false</canTargetBuildings>
                <canTargetAnimals>false</canTargetAnimals>
                <canTargetHumans>false</canTargetHumans>
                <canTargetMechs>false</canTargetMechs>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="CompProperties_AbilityGiveHediff">
                <compClass>CompAbilityEffect_GiveHediff</compClass>
                <hediffDef>BEWH_CaptainsOrderBuff</hediffDef>
                <onlyBrain>True</onlyBrain>
                <onlyApplyToSelf>True</onlyApplyToSelf>
                <replaceExisting>true</replaceExisting>
            </li>
        </comps>
    </AbilityDef>
</Defs>