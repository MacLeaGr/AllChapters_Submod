<?xml version="1.0" encoding="utf-8"?>
<Patch>

<!-- Base Example
<Operation Class="PatchOperationAdd">
        <xpath>Defs/Genes40k.ShoulderIconDef[defName = "BEWH_RankIconNeophyte"]/mustHaveRank</xpath>
        <value>
            <li>BEWH_AstartesRankNeophyte</li>
            <li>FERP_EmperorsSpearsRankNeophyte</li>
        </value>
    </Operation>
-->

    <!-- Add to Astartes -->
<Operation Class="PatchOperationAdd">
        <xpath>Defs/Core40k.RankCategoryDef[defName = "BEWH_AstartesRankCategory"]</xpath>
        <value>
            <lockedByGene>SHAD_ChapterXEmperorsSpears</lockedByGene>
        </value>
    </Operation>

    <!-- Add Emperor's Spears -->
